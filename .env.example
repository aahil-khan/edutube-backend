# Database
DATABASE_URL="postgresql://postgres:pgadmin@localhost:5433/Video_Portal_Dummy"

# JWT Secrets
ACCESS_SECRET_KEY="your_access_secret_key_here"
REFRESH_SECRET_KEY="your_refresh_secret_key_here"

# Redis (optional)
REDIS_URL="redis://localhost:6379"

# Server
NODE_ENV="development"
PORT=5001

# CORS
# Comma-separated browser origins allowed to call the backend directly.
# Include the LAN host/IP and any future internal DNS name.
CORS_ORIGINS="http://localhost,http://localhost:3000,http://localhost:4000,http://172.16.95.109,http://edutube.college.local"
